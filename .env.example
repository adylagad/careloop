AGENTVERSE_API_KEY=
ANTHROPIC_API_KEY=
ASI1_API_KEY=
ASI1_MODEL=asi1-mini
BROWSER_USE_API_KEY=
PHARMACY_BROWSER_PRICE_MODEL=gpt-5.4-mini
PHARMACY_BROWSER_PRICE_LIMIT=6
PHARMACY_BROWSER_PRICE_TIMEOUT_SECONDS=210
CARELOOP_MAILBOX=true

# Optional stable seeds. Replace before public deployment.
ORCHESTRATOR_AGENT_SEED=careloop orchestrator seed phrase change me
PHARMACY_AGENT_SEED=careloop pharmacy options seed phrase change me
PRESCRIPTION_STATUS_AGENT_SEED=careloop pharmacy options seed phrase change me
PHARMACY_ASSISTANT_AGENT_SEED=careloop pharmacy options seed phrase change me
PRESCRIPTION_AGENT_SEED=careloop prescription explainer seed phrase change me
APPOINTMENT_AGENT_SEED=careloop appointment booking seed phrase change me
CAREGIVER_AGENT_SEED=careloop caregiver notifier seed phrase change me
TRIAGE_AGENT_SEED=careloop triage seed phrase change me
ADHERENCE_AGENT_SEED=careloop adherence seed phrase change me
PAYMENT_BUYER_AGENT_SEED=careloop payment buyer demo seed phrase change me

# Optional ports.
ORCHESTRATOR_AGENT_PORT=8010
PHARMACY_AGENT_PORT=8011
PRESCRIPTION_AGENT_PORT=8012
APPOINTMENT_AGENT_PORT=8013
CAREGIVER_AGENT_PORT=8014
TRIAGE_AGENT_PORT=8015
ADHERENCE_AGENT_PORT=8016
PAYMENT_BUYER_AGENT_PORT=8017

# Optional local handoff targets.
PHARMACY_AGENT_ADDRESS=
PRESCRIPTION_STATUS_AGENT_ADDRESS=
PHARMACY_ASSISTANT_AGENT_ADDRESS=
PAYMENT_BUYER_MODE=commit
PAYMENT_BUYER_TASK=otc_order

# Optional real Fetch.ai Dorado/stable testnet settlement for the demo buyer.
# Keep this empty unless you fund a testnet wallet and want CommitPayment.transaction_id
# to be an actual chain tx hash instead of a demo id.
FET_ONCHAIN_PAYMENT=false
FET_TESTNET_MNEMONIC=
PHARMACY_ASSISTANT_FET_WALLET_ADDRESS=
